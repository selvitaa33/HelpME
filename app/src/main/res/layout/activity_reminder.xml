<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:background="@color/primary_blue"
        android:gravity="center_vertical" android:paddingStart="4dp" android:paddingEnd="16dp">
        <ImageButton android:id="@+id/btnBack"
            android:layout_width="48dp" android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_rew"
            android:tint="@color/white" android:contentDescription="Kembali" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Pengingat Minum Obat" android:textColor="@color/white"
            android:textSize="18sp" android:textStyle="bold" android:layout_marginStart="4dp" />
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:overScrollMode="never">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Status pengingat aktif -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardCornerRadius="10dp"
                app:cardElevation="3dp" app:cardBackgroundColor="#E3F2FD">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="16dp" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Status Pengingat" android:textColor="@color/primary_blue"
                        android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvReminderStatus"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Belum ada pengingat aktif"
                        android:textColor="@color/text_secondary" android:textSize="13sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Set Waktu -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Atur Pengingat" android:textColor="@color/text_primary"
                android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView android:id="@+id/btnSetMorning"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" app:cardCornerRadius="10dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white" android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="16dp" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Pengingat Pagi" android:textColor="@color/primary_blue"
                        android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvMorningTime"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ketuk untuk atur jam"
                        android:textColor="@color/text_secondary" android:textSize="13sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/btnSetAfternoon"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" app:cardCornerRadius="10dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white" android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="16dp" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Pengingat Siang" android:textColor="@color/primary_blue"
                        android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvAfternoonTime"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ketuk untuk atur jam"
                        android:textColor="@color/text_secondary" android:textSize="13sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/btnSetNight"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardCornerRadius="10dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white" android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="16dp" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Pengingat Malam" android:textColor="@color/primary_blue"
                        android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvNightTime"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ketuk untuk atur jam"
                        android:textColor="@color/text_secondary" android:textSize="13sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button android:id="@+id/btnCancelReminder"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Hapus Semua Pengingat"
                android:textColor="@color/text_secondary" android:textSize="14sp"
                android:backgroundTint="#E0E0E0" android:layout_marginBottom="16dp"/>

            <!-- Info -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="10dp" app:cardElevation="1dp" app:cardBackgroundColor="#FFF9C4">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="14dp" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Cara Penggunaan" android:textColor="#F57F17"
                        android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ketuk salah satu pengingat di atas, pilih jam yang diinginkan. Notifikasi akan muncul beserta suara pengingat minum obat."
                        android:textColor="#795548" android:textSize="12sp" android:layout_marginTop="4dp"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
