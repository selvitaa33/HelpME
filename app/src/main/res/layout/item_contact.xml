<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Avatar -->
        <FrameLayout
            android:layout_width="46dp"
            android:layout_height="46dp">
            <View
                android:id="@+id/viewAvatarBg"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_avatar_circle" />
            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="A"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />
        </FrameLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView
                android:id="@+id/tvContactName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Kontak"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvContactPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08123456789"
                android:textColor="@color/primary_blue"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
            <TextView
                android:id="@+id/tvContactRelation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Keluarga"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Tombol Aksi -->
        <ImageButton
            android:id="@+id/btnCall"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_button_green"
            android:src="@android:drawable/ic_menu_call"
            android:tint="@color/white"
            android:contentDescription="Telepon"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_button_red"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="@color/white"
            android:contentDescription="Hapus" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
