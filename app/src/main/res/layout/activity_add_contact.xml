<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/primary_blue"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_rew"
            android:tint="@color/white"
            android:contentDescription="Kembali" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tambah Kontak"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Nama -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Kontak"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Contoh: Ibu, Ayah, Pendamping"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:padding="12dp"
                android:background="@drawable/bg_edit_text_light"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp" />

            <!-- Nomor -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nomor Telepon"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Contoh: 08123456789"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:padding="12dp"
                android:background="@drawable/bg_edit_text_light"
                android:inputType="phone"
                android:layout_marginBottom="16dp" />

            <!-- Hubungan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hubungan"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/etRelation"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Contoh: Keluarga, Pendamping, Dokter"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:padding="12dp"
                android:background="@drawable/bg_edit_text_light"
                android:inputType="text"
                android:layout_marginBottom="28dp" />

            <!-- Tombol Simpan -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:text="Simpan Kontak"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="@color/primary_blue" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Batal"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:backgroundTint="#E0E0E0" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
